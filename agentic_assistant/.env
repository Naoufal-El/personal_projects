# .env
COMPOSE_PROJECT_NAME=agentic_assistant

# API Configuration
API_PORT=8000
API_HOST=0.0.0.0
CONTROLLER_TIMEOUT=240

# DB Configuration
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_IP=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_DATABASE=agentic_db

# Redis Configuration
REDIS_IP=127.0.0.1
REDIS_PORT=6379
REDIS_INDEX_DATABASE=0

# Ollama Configuration
LLM_IP=127.0.0.1
LLM_PORT=11434
LLM_MODEL=gemma3:4b
LLM_CONVERSATION_TEMPERATURE=0.7
LLM_GUARDRAILS_TEMPERATURE=0.0
LLM_RAG_TEMPERATURE=0.3
LLM_ROUTING_TEMPERATURE=0.1
LLM_VERBOSE=True
LLM_MAX_HISTORY_MSGS=8
LLM_EMBEDDING_MODEL=nomic-embed-text
LLM_MAX_TOKENS=512
VALIDATION_LAYER2_THRESHOLD=5
    # Output guardrail settings
OUTPUT_CONFIDENCE_THRESHOLD=0.5
MIN_RETRIEVED_CHUNKS=2
MAX_REGENERATION_ATTEMPTS=2
MIN_RESPONSE_LENGTH=20

# Qdrant Configuration
QDRANT_IP=127.0.0.1
QDRANT_PORT=6333
QDRANT_PROCESS_COLLECTION=process_kb
QDRANT_CUSTOMER_COLLECTION=customer_kb
QDRANT_VECTOR_SIZE=768
QDRANT_RETRIEVAL_ENABLED=true
QDRANT_RETRIEVAL_TOP_K=5

# Feature Flags
CLOUD_LLM_ENABLED=false

# Monitoring
LOG_LEVEL=INFO
TELEMETRY_ENABLED=false

# ============================================
# HYBRID MEMORY CONFIGURATION
# ============================================
# Memory Strategy
MEMORY_STRATEGY=hybrid

# Redis Cache Settings
REDIS_TTL_DAYS=30
REDIS_MAX_HISTORY_BUFFER=2

# PostgreSQL Settings
MAX_HISTORY_FROM_DB=100

# PostgreSQL Connection Pool
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_POOL_RECYCLE=3600

# Cache Behavior
CACHE_WARM_ON_LOAD=true

# ============================================
# DOCUMENT INGESTION CONFIGURATION
# ============================================

# Directory Paths (relative to project root)
INGESTION_PENDING_DIR=data/pending
INGESTION_PROCESSING_DIR=data/processing
INGESTION_COMPLETED_DIR=data/completed
INGESTION_FAILED_DIR=data/failed

# Supported File Formats
INGESTION_SUPPORTED_EXTENSIONS=.txt,.json,.csv,.pdf,.docx

# Job Scheduling
INGESTION_AUTO_SCAN_ENABLED=false
INGESTION_SCAN_INTERVAL_MINUTES=1

# Document Processing
INGESTION_CHUNK_SIZE=1000
INGESTION_CHUNK_OVERLAP=200
INGESTION_MIN_CHUNK_SIZE=100

# File Validation
INGESTION_MAX_FILE_SIZE_MB=10
INGESTION_MAX_CONCURRENT_FILES=5

# Batch Processing
INGESTION_BATCH_SIZE=10
INGESTION_RETRY_FAILED_FILES=true
INGESTION_MAX_RETRIES=3

# Qdrant Collection
INGESTION_CREATE_COLLECTION_IF_NOT_EXISTS=true

# ================================
# Validation Settings
# ================================
VALIDATION_MIN_LENGTH=2
VALIDATION_MAX_LENGTH=2000
VALIDATION_MAX_EMOJI_RATIO=0.1
VALIDATION_MAX_SPECIAL_CHAR_RATIO=0.3
VALIDATION_RATE_LIMIT_ENABLED=true
VALIDATION_MAX_REQUESTS_PER_MINUTE=20
VALIDATION_MAX_REQUESTS_PER_HOUR=200
VALIDATION_SPAM_DETECTION_ENABLED=true
VALIDATION_MAX_REPEATED_QUERIES=3
VALIDATION_STRATEGY=fail_fast

# ================================
# Security / Authentication
AUTH_SECRET_KEY=your-super-secret-jwt-key-change-in-production-minimum-32-characters
AUTH_MIN_TO_EXPIRE=120
AUTH_ALGORITHM=HS256